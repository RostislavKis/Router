{
	"luci-app-cf-optimizer": {
		"description": "Grant access to Proxy Optimizer",
		"read": {
			"uci": [ "cf_optimizer" ],
			"file": {
				"/var/run/latency-monitor.status": [ "read" ],
				"/var/run/mihomo-watchdog.status": [ "read" ],
				"/var/run/xray-fragment.status":   [ "read" ],
				"/var/run/cf-optimizer.status":    [ "read" ],
				"/var/log/latency-monitor.log":    [ "read" ]
			}
		},
		"write": {
			"uci": [ "cf_optimizer" ],
			"file": {
				"/usr/local/bin/latency-start.sh":     [ "exec" ],
				"/usr/local/bin/xray-control.sh":      [ "exec" ],
				"/usr/local/bin/xray-apply-config.sh": [ "exec" ],
				"/usr/local/bin/cf-ip-update.sh":      [ "exec" ],
				"/usr/local/bin/sni-scan.sh":           [ "exec" ]
			}
		}
	}
}
